rules_version = '2';

// WatchTogether — Firestore Security Rules
//
// Derived directly from the real read/write patterns in this project's
// repository/service layer (lib/repositories/*.dart, lib/services/*.dart),
// not written from a generic template. Every collection below is one of
// the 12 in lib/core/constants/firestore_collections.dart — no collection
// name here was invented.
//
// This is the file that was missing from the project entirely (there was
// no firestore.rules anywhere in the repo before this change), which is
// the most likely reason a freshly-created room's Video Player showed
// "Room Unavailable": with no rules deployed, a Firebase project's
// default/locked-mode behavior denies every client read, and the room
// (and its participants/messages/join-requests) simply couldn't be read
// back after creation.
//
// IMPORTANT — test before deploying to production:
//   firebase emulators:start --only firestore
//   (this sandbox has no network access to run that here; these rules
//   are correct against the traced code paths but were not exercised
//   against the emulator or a live project)

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Used by participants/join_requests to check "is the requester
    // this room's host" without duplicating hostId onto every document
    // — one extra read, same tradeoff RoomService.joinRoom already
    // makes with its own transactional room read.
    function isRoomHost(roomId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
    }

    // ---------------------------------------------------------------
    // users — UserRepository
    // Profile fields are read broadly (room host cards, friend search,
    // notification sender lookups, participant lists all fetch other
    // users' documents by uid — see UserRepository.getUser and
    // UserRepository.searchByDisplayNameLowercasePrefix). Only the
    // profile's own owner may create/update it; there's no client
    // delete-account path that removes the document itself.
    // ---------------------------------------------------------------
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // ---------------------------------------------------------------
    // rooms — RoomRepository / RoomService
    // Read is broad (Public Rooms on Home, invited joins, Room Details,
    // Video Player all read rooms they didn't create). Create is
    // host-only. Update covers three real call sites: host actions
    // (RoomRepository.updatePlaybackState, updateParticipantMuted-
    // adjacent host controls), a participant joining/leaving
    // (RoomService.joinRoom / leaveRoomAndTransferHostIfNeeded, which
    // writes participantIds — and can reassign hostId on transfer, so
    // this can't be pinned to "only the host may write"), and playback
    // control by a non-host participant when RoomModel.allowScreenControl
    // is true (they're already in participantIds by then).
    // ---------------------------------------------------------------
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.hostId == request.auth.uid ||
        request.auth.uid in resource.data.participantIds ||
        request.auth.uid in request.resource.data.participantIds
      );
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;
    }

    // ---------------------------------------------------------------
    // participants — RoomService (doc id = ParticipantModel.buildId,
    // i.e. deterministic per roomId+userId, but rules key off the
    // document's own userId/roomId fields rather than parsing the id).
    // Read broad (every room member's list is shown to every other
    // member). A user creates only their own participant doc (joining).
    // Update/delete allowed for the participant themself (mute
    // toggle, leaving) OR the room's host (mute-others, kick —
    // RoomRepository's admin controls).
    // ---------------------------------------------------------------
    match /participants/{participantId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isRoomHost(resource.data.roomId)
      );
    }

    // ---------------------------------------------------------------
    // messages — MessageRepository.sendMessage/deleteMessage
    // Chat is readable by any signed-in user (no separate "is a member
    // of this room" check exists elsewhere in the app either — the
    // Video Player already assumes anyone who can open a room can see
    // its chat). A message may only be created as yourself, and
    // deleted either by its own sender or the room's host (moderation
    // — deleteMessage has no caller yet, this is forward-compatible
    // with it, matching the host-moderation pattern participants
    // already has).
    // ---------------------------------------------------------------
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        isRoomHost(resource.data.roomId)
      );
      allow update: if false; // no edit-message feature exists
    }

    // ---------------------------------------------------------------
    // friends — FriendService (doc id = sorted userIdA_userIdB pair;
    // rules key off the userId/friendId fields, both directions).
    // ---------------------------------------------------------------
    match /friends/{friendshipId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.friendId == request.auth.uid);
      allow create: if isSignedIn() &&
        (request.resource.data.userId == request.auth.uid ||
         request.resource.data.friendId == request.auth.uid);
      allow update, delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.friendId == request.auth.uid);
    }

    // ---------------------------------------------------------------
    // friend_requests — FriendService.sendFriendRequest/accept/decline.
    // Create only as the real requester (requestedBy AND one of the
    // two parties must be you — sendFriendRequest always sets
    // requestedBy: fromUserId, userId: fromUserId). Accept/decline both
    // delete the document (see FriendService's own doc comments) rather
    // than updating it in place, so update is never needed.
    // ---------------------------------------------------------------
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.friendId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.requestedBy == request.auth.uid &&
        (request.resource.data.userId == request.auth.uid ||
         request.resource.data.friendId == request.auth.uid);
      allow delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.friendId == request.auth.uid);
      allow update: if false;
    }

    // ---------------------------------------------------------------
    // notifications — NotificationRepository.
    // A notification's userId field is the RECIPIENT, not its creator
    // (a room-invite/friend-request notification is written by the
    // sender for someone else) — create can't require
    // request.auth.uid == userId the way most other collections do.
    // Kept to signed-in-only plus a basic shape check so a client can't
    // write arbitrary junk fields. Only the recipient may read/mark-
    // read/delete their own inbox (markAllAsRead/deleteReadNotifications
    // both operate strictly within the caller's own userId).
    // ---------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.userId is string &&
        request.resource.data.type is string &&
        request.resource.data.title is string &&
        request.resource.data.body is string;
    }

    // ---------------------------------------------------------------
    // watch_history — WatchHistoryRepository.upsertProgress (doc id =
    // WatchHistoryModel.buildId(userId, roomId), own-user only).
    // ---------------------------------------------------------------
    match /watch_history/{entryId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ---------------------------------------------------------------
    // join_requests — RoomRepository.requestToJoin/accept/reject
    // (Home's Public Rooms review flow, and the Notifications screen's
    // admin-facing "X wants to join Y" cards). Only the requester
    // themself may create one, as themself. Read/delete allowed for
    // the requester (their own pending state, or cancelling) or the
    // room's host (reviewing/accepting/rejecting).
    // ---------------------------------------------------------------
    match /join_requests/{requestId} {
      allow read, delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isRoomHost(resource.data.roomId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // accept/reject both delete, per RoomRepository's doc comments
    }

    // ---------------------------------------------------------------
    // premium — PremiumRepository (doc id = uid).
    // NOTE: activatePremium currently writes isActive/tier/etc.
    // directly from the client with no server-side purchase
    // verification. These rules only enforce "you may only touch your
    // own premium document" — they do not and cannot verify that a
    // real purchase happened. Before real payments go live, this
    // should move to a Cloud Function (verifying the App Store/Play
    // receipt) with rules changed to deny client writes entirely.
    // Flagged here, not silently changed, since tightening it now
    // would break the existing (client-only) purchase flow.
    // ---------------------------------------------------------------
    match /premium/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ---------------------------------------------------------------
    // reports — ReportRepository. Write-mostly by design (its own doc
    // comment: review/actioning happens from an admin tool, not this
    // client) — so a report, once submitted, is not readable back
    // except by its own submitter (streamReportsSubmittedBy), and
    // never updatable/deletable from the client.
    // ---------------------------------------------------------------
    match /reports/{reportId} {
      allow read: if isSignedIn() && resource.data.reporterId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------------------------------------------------------------
    // app_settings — AppSettingsRepository (single doc, id "global").
    // Read-only global config; never written by any client code path.
    // ---------------------------------------------------------------
    match /app_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Deny anything not explicitly matched above (e.g. a future
    // collection someone adds without updating this file).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
